<%- include("Header/Header") %>

<style>
    .hhh{
        max-width: 500px;
    }
</style>

<div class="container py-4">

    <div class="row g-3 justify-content-center">

        <% bookmovie.map((item)=>{ %>

        <div class="col-12 hhh">

            <div class="card shadow-sm border-0 rounded-4 h-100">

                <!-- Movie Image -->
                <img 
                    src="<%= item.Image %>" 
                    class="card-img-top rounded-top-4"
                    style=" object-fit:cover;"
                >

                <div class="card-body p-3">

                    <h5 class="fw-bold text-center">
                        <%= item.MovieName %>
                    </h5>

                    <p class="small text-muted mb-2">
                        <strong>Description:</strong>
                        <%= item.Description %>
                    </p>

                    <p class="mb-1">
                        ⭐ <strong>Rating:</strong>
                        <%= item.Rating %>
                    </p>

                    <p class="mb-1">
                        <strong>Actors:</strong>
                        <%= item.Actors %>
                    </p>

                    <p class="mb-1">
                        <strong>Show Duration:</strong><br>
                        <%= item.ReleaseDate %> <span class="fw-bold"> to </span> <%= item.EndDate %>
                    </p>

                    <p class="mb-1">
                        <strong>Time:</strong>
                        <%= item.Time %>
                    </p>

                    <p class="mb-2 text-success fw-bold">
                        <span class="text-dark"><strong>Price:</strong></span>
                       <i class="bi bi-currency-rupee"></i> <%= item.Price %>
                    </p>

                </div>

                <!-- Theater Info -->
                <div class="card-footer bg-light border-0 px-3">

                    <% item.theaterdata.map((data)=>{ %>

                    <div class="mb-2 p-2 rounded bg-white shadow-sm">

                        <h6 class="mb-2">
                            🎭
                            <span class="badge bg-danger">
                                <%= data.TheaterName %>
                            </span>
                        </h6>

                        <p class="small mb-1">
                            <strong>Seats:</strong>
                            <%= data.Availableseats %>
                        </p>

                        <p class="small mb-1">
                            <strong>Location:</strong>
                            <%= data.Theaterlocation %>
                        </p>

                        <p class="small mb-0">
                            <strong>Opening:</strong>
                            <%= data.Openingtime %>
                        </p>

                    </div>

                    <% }) %>

                </div>

                <!-- Buttons -->
                <div class="d-flex gap-2 p-3">

                    <form action="/bookconfirm" method="get" class="w-100 text-center">

                        <input type="hidden" name="id" value="<%= item._id %>">
                        

                        <button type="submit" class="btn btn-warning btn-sm w-50"> Book Confirm</button>

                    </form>

                    <!-- <button class="btn btn-success btn-sm w-50"> See More </button> -->

                </div>

            </div>

        </div>

        <% }) %>

    </div>

</div>




<%- include("Footer/Footer") %>