
 <%- include("Header/Header")%>

   <h1 class="book">This is seat booking page</h1>

<div class="container mt-4">

    

   

<% confirmmovie.map((item)=>{ %>
     <div class=" col-md-4 mb-4">
        <div class="card h-100 shadow">

          <img src="<%= item.Image %>" class="card-img-top" style="height:250px; object-fit:cover;">

          <div class="card-body">
            <h3 class="card-title"><%= item.MovieName %></h3>

            <p class="card-text"><strong>Description:</strong> <%= item.Description %></p>
            <p class="card-text"><strong>Rating:</strong> ⭐ <%= item.Rating %></p>

            <p class="card-text"><strong>Actors:</strong> <%= item.Actors %></p>

            <p><strong>Release:</strong> <%= item.ReleaseDate %></p>
            <p><strong>Time:</strong> <%= item.Time %></p>
          </div>

          <div class="card-footer bg-white">

            <% item.theaterdata.map((data)=>{ %>

            <h3>Theater: <span class="badge bg-danger me-1 fs-5 px-3 py-2"><%= data.TheaterName %></span></h3>

                 
            <p><strong>Total Seats:</strong><%=data.Availableseats%></p>
            <span><strong>location:</strong><%=data.Theaterlocation%>,</span>
            <span><%=data.City%>,</span>
            <span><%=data.State%></span>
            <p><strong>Opening time:</strong><%=data.Openingtime%></p>


            

            <% let seats = Number(data.Availableseats) %>

            <div style="display:flex; flex-wrap:wrap; width: 300px;">
            
              <% for(let i = 1; i <=seats ; i++) { %>

                
            
                <div class="seat" onclick="selectSeat(this)" data-app-tid="<%=item.forid%>" data-app-mid="<%= item._id%>"
                     style=" width:40px;
                       height:40px;
                       margin:5px;
                       background:red;
                       color:white;
                       display:flex;
                       align-items:center;
                       justify-content:center;
                       border-radius:5px;
                       cursor:pointer; ">
                  <%= i %>
                </div>

                
              <% } %>
            
            </div>

            
            <!-- <div class="border border-danger">
              <p>Booking Summary</p>
              <h4>Selected Seats: <span id="seatCount">0</span></h4>
              <h4>Prise Per Seat: 100rs</h4>
              <h3>Total Price:<span class="text-danger fs-1"  id="totalPrice">0</span></h3>
            </div> -->
 
           <% }) %>

          </div>


          <div class="d-flex justify-content-around mt-3 mb-4">
           <form action="/bookconfirm" method="get" style="display:inline;">
                 <input type="hidden" name="id" value="<%= item._id %>">
                  <button type="submit">Book Now</button>
                </form>
            <button class="btn btn-success w-30">See More</button>
          </div>

        </div>
      </div>

    <% }) %>

  

    


 <script>

  const seats=[];


 function selectSeat(element) {

  var mid=element.getAttribute("data-app-mid");
  var tid=element.getAttribute("data-app-tid");

  seats.push(element.innerText)
  console.log("new data")
  console.log(seats);
  console.log(mid);
  console.log(tid);
  

  
  if (element.style.background === "red") {
   element.style.background = "green";
  } else {
   element.style.background = "red";
  }
}

</script>

</div>




<%- include("Footer/Footer")%>















<script>

let pricePerSeat = 100;

function selectSeat(element) {

  
  if (element.style.background === "red") {
   element.style.background = "green";
    element.classList.add("selected"); 
  } else {
   element.style.background = "red";
    element.classList.remove("selected"); 
  }

  
  let selectedSeats = document.querySelectorAll(".seat.selected");
  let count = selectedSeats.length;

  let total = count * pricePerSeat;

  
  document.getElementById("seatCount").innerText = count;
  document.getElementById("totalPrice").innerText = total;
}

</script>





