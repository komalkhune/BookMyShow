<h1 class="booking-title">This is seat booking page</h1>

<div class="main-container">

<% confirmmovie.forEach((item)=>{ %>

<div class="movie-card">

    <div class="top-row">


        <div class="image-section">
            <img src="<%= item.Image %>" class="movie-image">
        </div>


        <div class="details-section">

            <h2 class="movie-name">
                <span id="mname"><%= item.MovieName %></span>
            </h2>

            <p><strong>Description:</strong> <%= item.Description %></p>
            <p><strong>Rating:</strong> ⭐ <%= item.Rating %></p>
            <p><strong>Actors:</strong> <%= item.Actors %></p>
            <p><strong>Show Duration</strong></p>

            <p>
                <strong>From:</strong>
                <span id="msdate"><%= item.ReleaseDate %></span>
            </p>

            <p>
                <strong>To:</strong>
                <span id="medate"><%= item.EndDate %></span>
            </p>

            <p>
                <strong>Time:</strong>
                <span id="mtime"><%= item.Time %></span>
            </p>

            <p>
                <strong>Price:</strong>
                <span id="mprice"><%= item.Price %></span>
            </p>

        </div>

    </div>

    
    <div class="theater-section">

    <% item.theaterdata.forEach((data)=>{ %>

        <h3>
            Theater:
            <span class="theater-badge" id="tname">
                <%= data.TheaterName %>
            </span>
        </h3>

        <p>
            <strong>Total Seats:</strong>
            <%= data.Availableseats %>
        </p>

        <p>
            <strong>Location:</strong>

            <span id="tlocation">
                <%= data.Theaterlocation %>
            </span>,

            <span id="tcity">
                <%= data.City %>
            </span>,

            <span id="tstate">
                <%= data.State %>
            </span>
        </p>

        <p>
            <strong>Opening Time:</strong>
            <%= data.Openingtime %>
        </p>

        <% let seats = Number(data.Availableseats) %>

        <label>
            <strong>Choose Date</strong>
        </label>

        <input
            type="date"
            placeholder="choose date for booking"
            id="inp"
            name="bdate"
        >

        <% let bookedSeats = (ubseats && ubseats[ubdate]) || []; %>

        <div class="seat-box">

        <% for(let i = 1; i <= seats; i++) { %> 

            <% if(bookedSeats.includes(i.toString())) { %>

                <div
                    class="seat bg-danger"
                    onclick="alert('This Seat Already Booked! Choose another Seat')"
                >
                    <%= i %>
                </div>

            <% } else { %>

                <div
                    class="seat"
                    onclick="selectSeat(this)"
                >
                    <%= i %>
                </div>

            <% } %>

        <% } %>

        </div>

    <% }) %>

    </div>

    <div
        id="msg"
        style="color:red; font-size:25px; text-align:center; margin:10px 0;"
    >
    </div>

    
    <div class="button-area">

        <button
            type="submit"
            class="book-btn"
            onclick="booknow(this)"
            data-app-tid="<%= item.forid %>"
            data-app-mid="<%= item._id %>"
        >
            Book Now
        </button>

        <button class="more-btn">
            See More
        </button>

    </div>

</div>

<% }) %>

</div>

<% } %>







