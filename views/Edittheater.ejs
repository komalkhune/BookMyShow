<%- include("Header/Header")%>


<style>
    header{
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    background: #000000;
    z-index: 100;
    padding: 10px;
}

.navbar{
    padding: 0 15px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    z-index: 10;
}
.logo img{
    height: 3.5rem;
} 
.content{
    margin-top: 50px;
}
.form-label{
    font-weight: bold;
}


</style>

<div class="container py-5">

      <header>

        <nav class="navbar">

            <div class="logo"><img src="../public/images/Screenshot 2026-05-24 124716.png"/></div>
        
            
            <div class="nav-right">
        
            </div>

        </nav>

    </header>

    <div class="row justify-content-center content">
        <div class="col-12 col-md-8 col-lg-6">

            <div class="card shadow-lg border-0 rounded-4 p-4">

                <h2 class="text-center mb-4 text-primary">
                    Edit Theater
                </h2>

                <form action="/updatetheater" method="POST">

                    <input type="hidden" name="id" value="<%= theaterdata._id %>">
                    <input type="hidden" name="fid" value="<%= fid %>">

                    <label class="form-label">Theater Name</label>
                    <input type="text" name="tname" value="<%= theaterdata.TheaterName %>" class="form-control mb-3" required>

                    <label class="form-label">Available Seats</label>
                    <input type="text" name="tseats" value="<%= theaterdata.Availableseats %>" class="form-control mb-3" required>

                    <label class="form-label">Opening Time</label>
                    <input type="time" name="totime" value="<%= theaterdata.Openingtime %>" class="form-control mb-3" required>

                    <label class="form-label">Email</label>
                    <input type="email" name="tmail" value="<%= theaterdata.Theatermail %>" class="form-control mb-3" required>

                    <label class="form-label">Password</label>
                    <input type="text" name="pass" value="<%= theaterdata.Theaterpass %>" class="form-control mb-3" required>

                    <label class="form-label">Landmark</label>
                    <input type="text" name="tlocation" value="<%= theaterdata.Theaterlocation %>" class="form-control mb-3">

                    <label class="form-label">Country</label>
                    <input type="text" name="tcountry" value="<%= theaterdata.Country %>" class="form-control mb-3">

                    <label class="form-label">State</label>
                    <input type="text" name="tstate" value="<%= theaterdata.State %>" class="form-control mb-3">

                    <label class="form-label">City</label>
                    <input type="text" name="tcity" value="<%= theaterdata.City %>" class="form-control mb-4">

                    <button type="submit" class="btn btn-warning w-100 rounded-pill py-2"> Update Theater</button>

                </form>

            </div>

        </div>
    </div>

</div>

<%- include("Footer/Footer")%>