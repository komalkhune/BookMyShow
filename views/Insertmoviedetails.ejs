<%- include("Header/Header") %>

<style>
    header{
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    background: #000000;
    z-index: 100;
    padding: 10px;
}

.navbar{
    padding: 0 15px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    z-index: 10;
}
.logo img{
    height: 2rem;
} 
.contain{
    margin-top: 50px;
}
.logout{
    text-decoration: none;
    color: #f5f6fa;
     width: 100px;
     /* margin-top: 20px; */
    padding: 5px;
    border-radius: 10px;
     background: linear-gradient(135deg, #4a00df, #72007b);
}

</style>

<div class="container py-5 contain">

     <header>

        <nav class="navbar">

            <div class="logo"><img src="../public/images/Screenshot 2026-05-24 124716.png"/></div>
        
            
            <div class="nav-right">
                 <a class="logout ms-4"  href="/"><i class="bi bi-box-arrow-left"></i> Logout</a>
            </div>

        </nav>

    </header>

    <!-- Top Buttons -->
    <div class="row justify-content-center mb-4 g-3">

        <div class="col-md-3 col-sm-6">
            <form action="/movies" method="get">
                <input type="hidden" value="<%= tuid %>" name="fid"/>
                <button  type="submit" class="btn btn-warning w-100 fw-bold py-3 rounded-4 shadow"> Show My Movies </button>
            </form>
        </div>

        <div class="col-md-3 col-sm-6">
            <form action="/theaters" method="get">
                <input type="hidden" value="<%= tuid %>" name="fid"/>

                <button  type="submit" class="btn btn-info w-100 fw-bold py-3 rounded-4 shadow text-white"> Show My Theater</button>
            </form>
        </div>

    </div>

    <!-- Movie Form Card -->
    <div class="row justify-content-center content">
        <div class="col-lg-8 col-md-10">

            <div class="card border-0 shadow-lg rounded-4 bg-dark bg-opacity-75 text-light">

                <div class="card-body p-4 p-md-5">

                    <div class="text-center mb-4">
                        <h1 class="fw-bold text-warning">
                            🎥 Insert Movie Details
                        </h1>
                    </div>

                    <form method="post" action="/getmovieinfo">

                        <div class="row">

                            <div class="col-md-6 mb-3">
                                <input  type="text" placeholder="Enter Movie Name" name="mname" class="form-control form-control-lg rounded-3" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <input  type="text" placeholder="Movie Description" name="mdesc" class="form-control form-control-lg rounded-3"/>
                            </div>

                            <div class="col-md-6 mb-3">
                                <input  type="text" placeholder="Movie Image URL" name="mimage" class="form-control form-control-lg rounded-3"  />
                            </div>

                            <div class="col-md-6 mb-3">
                                <input  type="number" placeholder="Movie Rating" name="mrating" class="form-control form-control-lg rounded-3" />
                            </div>

                            <div class="col-12 mb-3">
                                <input  type="text" placeholder="Enter Actors" name="mactors" class="form-control form-control-lg rounded-3" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Show Duration From</label>

                                <input  type="date" name="sdate" class="form-control form-control-lg rounded-3"/>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Show Duration To</label>

                                <input  type="date" name="edate" class="form-control form-control-lg rounded-3"/>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Movie Time</label>

                                <input  type="time" name="mtime" class="form-control form-control-lg rounded-3" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <input  type="number" placeholder="Movie Price" name="mprice" class="form-control form-control-lg rounded-3" />
                            </div>

                        </div>

                        <input  type="hidden" value="<%= tuid %>" name="fid"/>

                        <button  type="submit" class="btn btn-warning w-100 fw-bold py-3 rounded-4 mt-3"> ➕ Add Movie</button>

                        <% if(message){ %>
                            <!-- <div class="alert alert-success mt-4 text-center rounded-3"> -->
                            <div class="alert alert-danger fs-3 mt-4 text-center rounded-3">
                                <%= message %>
                            </div>
                        <% } %>

                    </form>

                </div>

            </div>

        </div>
    </div>

</div>



<%- include("Footer/Footer") %>