

<%- include("Header/Header") %> 

<style>
    header{
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    background: #000000;
    z-index: 100;
    padding: 10px;
}

.navbar{
    padding: 0 15px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    z-index: 10;
}
.logo img{
    height: 3rem;
} 
.main{
    margin-top: 100px;
}

</style>


 <header>

        <nav class="navbar">

            <div class="logo"><img src="../public/images/Screenshot 2026-05-24 124716.png"/></div>
        
            
            <div class="nav-right">
        
            </div>

        </nav>

    </header>

<div class="container py-5 main">

    <% if(message){ %>
        <div class="alert alert-success text-center shadow-sm">
            <%= message %>
        </div>
    <% } %>

    <div class="text-center mb-5">
        <h1 class="fw-bold"> Movie Booking</h1>
        <p class="text-muted">
            Watch your favorite movies near you
        </p>
    </div>

    <div class="d-flex flex-column flex-md-row justify-content-center gap-3">

        <a href="/moviewiththeater" class="btn btn-warning btn-lg shadow">
            <i class="bi bi-film"></i>   Show All Movies
        </a>

        <button 
            type="button" 
            class="btn btn-primary btn-lg shadow"
            data-bs-toggle="modal" 
            data-bs-target="#exampleModal">

            <i class="bi bi-geo-fill text-danger"></i> Select Location
        </button>

    </div>

</div>


<!-- Modal -->
<div class="modal fade" id="exampleModal" >
    
    <div class="modal-dialog modal-dialog-centered">

        <div class="modal-content rounded-4 shadow">

            <div class="modal-header border-0">
                <h4 class="modal-title fw-bold">
                    <i class="bi bi-geo-fill text-danger"></i> Select Your Location
                </h4>

                <button 
                    type="button" 
                    class="btn-close" 
                    data-bs-dismiss="modal">
                </button>
            </div>

            <div class="modal-body p-4">

                <form method="post" action="/ulocation">

                    <div class="mb-3">
                        <label class="form-label fw-semibold"> Country
                        </label>

                        <select  name="country"  id="country" onchange="getState()" class="form-select">

                            <option value=""> Select Country </option>

                            <option value="india"> India </option>

                            <option value="usa"> USA </option>

                        </select>
                    </div>


                    <div class="mb-3">
                        <label class="form-label fw-semibold"> State </label>

                        <select  name="state"  id="state" onchange="getCity()" class="form-select">

                            <option value=""> Select State </option>

                        </select>
                    </div>


                    <div class="mb-4">
                        <label class="form-label fw-semibold"> City</label>

                        <select  name="city"  id="city" class="form-select">
                            <option value="">Select City </option>
                        </select>
                    </div>


                    <button type="submit" class="btn btn-success w-100 py-2"> Confirm Location </button>

                </form>

            </div>

            <div class="modal-footer border-0">
                <button  type="button"  class="btn btn-secondary w-100" data-bs-dismiss="modal"> Close</button>
            </div>

        </div>

    </div>

</div>




<script>
  function getState() {
  let country = document.getElementById("country").value;
  let state = document.getElementById("state");

  // clear old data
  state.innerHTML = "<option>Select State</option>";

  if (country == "india") {
    state.innerHTML += "<option>Maharashtra</option>";
    state.innerHTML += "<option>Gujarat</option>";
  }

  if (country == "usa") {
    state.innerHTML += "<option>Texas</option>";
    state.innerHTML += "<option>California</option>";
  }
}

function getCity() {
  let state = document.getElementById("state").value;
  let city = document.getElementById("city");

  // clear old data
  city.innerHTML = "<option>Select City</option>";

  if (state == "Maharashtra") {
    city.innerHTML += "<option>Pune</option>";
    city.innerHTML += "<option>Mumbai</option>";
    city.innerHTML += "<option>Nagpur</option>";

  }

  if (state == "Gujarat") {
    city.innerHTML += "<option>Surat</option>";
    city.innerHTML += "<option>Ahmedabad</option>";
    city.innerHTML += "<option>Vadodara</option>";

  }

  if (state == "Texas") {
    city.innerHTML += "<option>Dallas</option>";
    city.innerHTML += "<option>Houston</option>";
  }

  if (state == "California") {
    city.innerHTML += "<option>Los Angeles</option>";
    city.innerHTML += "<option>San Diego</option>";
  }
}
</script>

</div>
  
