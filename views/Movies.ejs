<%- include("Header/Header")%>

<style>
    body{
        background: #f5f5f5;
    }

    .movie-card img{
        height: 220px;
        object-fit: cover;
    }

    .movie-card{
        transition: 0.3s;
    }

    .movie-card:hover{
        transform: translateY(-5px);
    }
        header{
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    background: #000000;
    z-index: 100;
    padding: 10px;
}

.navbar{
    padding: 0 15px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    z-index: 10;
}
.nav-right{
    display: flex;
    justify-content: center;
    align-items: center;
}
.logo img{
    height: 3rem;
} 
.content{
    margin-top: 50px;
}
.logout{
    font-size: 12px;
    text-decoration: none;
    color: #f5f6fa;
     width: 80px;
     /* margin-top: 20px; */
    padding: 3px;
    border-radius: 10px;
     background: linear-gradient(135deg, #4a00df, #72007b);
     display: flex;
     justify-content: space-around;
     align-items: center;
}

@media(min-width:768px){

    .logo img{
    height: 4rem;
} 
.logout{
     font-size: 16px;
      width: 100px;
       padding: 8px;
}

}
</style>



<div class="container py-4">


      <header>

        <nav class="navbar">

            <div class="logo"><img src="../public/images/Screenshot 2026-05-24 124716.png"/></div>
        
            
            <div class="nav-right">

             <form class="d-none d-md-flex" method="post" action="/searchmovie">
                  <div class="input-group shadow-sm">
                    <input  type="text" placeholder="Search Movie..." name="search" class="form-control rounded-start-pill" />

                    <button  type="submit" class="btn btn-primary rounded-end-pill px-4"> Search</button>

                </div>

                
            </form>  

             <a class="logout ms-4"  href="/showtheaterlogin"><i class="bi bi-box-arrow-left"></i> Logout</a>

            
        
            </div>

        </nav>

    </header>

    <% if(message){ %>

        <div class="text-center">
            <div class="alert alert-success shadow-sm">
                <h5><%= message %></h5>
            </div>

            <a href="/showmovieinsertfrm" class="btn btn-info rounded-pill px-4"> ← Back </a>
        </div>

    <% } else { %>


    <!-- Search Bar -->
    <div class="row justify-content-center mb-4 content">
        <div class="col-lg-5 col-md-8">

            <form class="d-md-none" method="post" action="/searchmovie">
                <div class="input-group shadow-sm">
                    <input  type="text" placeholder="Search Movie..." name="search" class="form-control rounded-start-pill" />

                    <button  type="submit" class="btn btn-primary rounded-end-pill px-4"> Search</button>

                </div>
            </form>

        </div>
    </div>

    <!-- Heading -->
    <h2 class="text-center fw-bold mb-4">
        🎬 All Movies
    </h2>

    <!-- Movie Cards -->
    <div class="row g-4">

        <% pictures.map((data)=>{ %>

        <div class="col-xl-3 col-lg-4 col-md-6 col-sm-6">

            <div class="card movie-card shadow border-0 rounded-4 h-100">

                <img  src="<%= data.Image %>"  class="card-img-top rounded-top-4" alt="movie image"/>

                <div class="card-body">

                    <h5 class="fw-bold text-primary"> <%= data.MovieName %></h5>

                    <p class="small text-muted"> <%= data.Description %></p>

                    <p class="mb-1"> ⭐ <strong>Rating:</strong>  <%= data.Rating %></p>

                    <p class="mb-1">
                        🎭 <strong>Actors:</strong>

                        <% if(Array.isArray(data.Actors)){ %>
                            <%= data.Actors.join(", ") %>
                        <% } else { %>
                            <%= data.Actors %>
                        <% } %>
                    </p>

                    <p class="mb-1"> 📅 <strong>From:</strong>  <%= data.ReleaseDate %></p>

                    <p class="mb-1"> 📅 <strong>To:</strong>  <%= data.EndDate %></p>

                    <p class="mb-1"> ⏰ <strong>Time:</strong>  <%= data.Time %></p>

                    <p class="mb-3"> 💰 <strong>Price:</strong> ₹ <%= data.Price %></p>

                    
                    <div class="d-flex gap-2">

                        <form action="/deletemovie" method="GET" class="w-50">
                            <input  type="hidden" name="id" value="<%= data._id %>">
                            <input  type="hidden" name="fid" value="<%= tuid %>">
                            <button  type="submit" class="btn btn-danger w-100 rounded-pill"> Delete</button>
                        </form>

                        <form action="/editmovie" method="GET" class="w-50">

                            <input  type="hidden" name="id" value="<%= data._id %>">
                            <input  type="hidden" name="fid" value="<%= tuid %>">
                            <button  type="submit" class="btn btn-warning w-100 rounded-pill text-dark"> Edit</button>

                        </form>

                    </div>

                </div>

            </div>

        </div>

        <% }) %>

    </div>

    <% } %>

</div>

<%- include("Footer/Footer")%>