<%- include("Header/Header")%>


<style>
    body{
        background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.7)),
        url("https://images.unsplash.com/photo-1489599849927-2ee91cede3ba");
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        min-height: 100vh;
    }
</style>

<div class="container min-vh-100 d-flex justify-content-center align-items-center">

    <div class="card shadow-lg border-0 rounded-4 col-12 col-sm-10 col-md-8 col-lg-5 bg-dark bg-opacity-75 text-light">

        <div class="card-body p-4 p-md-5">

            <div class="text-center mb-4">
                <h1 class="fw-bold text-warning">Verify OTP</h1>
                <p class="text-light-emphasis">
                    Enter the OTP sent to your email
                </p>
            </div>

            <form action="/verifyloginotp" method="POST">

                <div class="mb-3">
                    <input type="text" name="uotp" placeholder="Enter Correct OTP" class="form-control form-control-lg rounded-3 text-center"/>
                </div>

                <button type="submit" class="btn btn-warning w-100 fw-bold py-2 rounded-3"> Verify OTP</button>

            </form>

            <% if(message){ %>
                <div class="alert alert-danger mt-3 text-center rounded-3">
                    <%= message %>
                </div>
            <% } %>

            <div class="text-center mt-4">
                <a href="/showtheaterlogin" class="btn btn-outline-light rounded-pill px-4">
                    ← Go To Login
                </a>
            </div>

        </div>

    </div>

</div>


<%- include("Footer/Footer")%>