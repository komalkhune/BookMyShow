<%- include("Header/Header")%>


<style>
    header{
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    background: #000000;
    z-index: 100;
    padding: 10px;
}

.navbar{
    padding: 0 15px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    z-index: 10;
}
.logo img{
    height: 3rem;
} 
.main{
  margin-top: 100px;
}

</style>

<div class="container">


   <header>

        <nav class="navbar">

            <div class="logo"><img src="../public/images/Screenshot 2026-05-24 124716.png"/></div>
        
            
            <div class="nav-right">

              <form method="post" action="/searchmovies">
                 <input  type="text"  class=" border-0 py-2 mb-2 rounded-pill px-3" placeholder="Search another Movie..." name="search" />
                 <button class="btn btn-danger px-4" type="submit"> Search </button>
              </form>
        
            </div>

        </nav>

    </header>



<% if(!singlemovie || singlemovie.length === 0){ %>
    <h2>No Movie found</h2>
<% } else { %>

 


<% singlemovie.map((item)=>{ %>
     <div class="col-md-4 mb-4 main">
        <div class="card h-100 shadow">

          <img src="<%= item.Image %>" class="card-img-top" style="height:250px; object-fit:cover;">

          <div class="card-body">
            <h3 class="card-title"><%= item.MovieName %></h3>

            <p class="card-text"><strong>Description:</strong> <%= item.Description %></p>
            <p class="card-text"><strong>Rating:</strong> ⭐ <%= item.Rating %></p>

            <p class="card-text">
              
              <p><strong>Actors:</strong> : <%= item.Actors%></p>
            </p>
             
            <p><strong>Show Duration:</strong></p>
            <p><strong>from:</strong> <%= item.ReleaseDate %></p>
            <p><strong>To:</strong> <%= item.EndDate %></p>
            <p><strong>Time:</strong> <%= item.Time %></p>
            <p><strong>price:</strong> <%= item.price %></p>

          </div>

          <div class="card-footer bg-white">


          
             <% item.theaterdata.map((data)=>{ %>
            <h3>Theater: <span class="badge bg-danger me-1 fs-5 px-3 py-2"><%= data.TheaterName %></span></h3>

                 
                 <p><strong>Total Seats:</strong><%=data.Availableseats%></p>
                 <p><strong>location:</strong><%=data.Theaterlocation%></p>
                 <p><strong>Opening time:</strong><%=data.Openingtime%></p>

                 
            <% }) %>

            
          </div>


            <div class="d-flex justify-content-around mt-3 mb-4">

             <form action="/bookconfirm" method="get" style="display:inline;">
                   <input type="hidden" name="id" value="<%= item._id %>">
                    <!-- <button type="submit">Book Confirm</button> -->
                     <button class="btn btn-info px-4" type="submit"> Book </button>
                  </form>


            </div>

        </div>
      </div>

    <% }) %>

<% } %>

</div>





<%-  include("Footer/Footer") %>